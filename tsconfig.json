{
  "compilerOptions": {
    // File layout
    "rootDir": "src",           // source files folder
    "outDir": "dist",           // compiled JS output folder

    // Environment settings
    "target": "ES2020",         // modern JS
    "module": "CommonJS",       // Node uses CommonJS
    "esModuleInterop": true,    // allow import/export interop

    // Type checking
    "strict": true,             // strict type checking
    "skipLibCheck": true,       // skip checking node_modules types

    // Optional helpful flags
    "sourceMap": true           // generate source maps
  },
  "include": ["src/**/*"]       // include all TS files in src/
}